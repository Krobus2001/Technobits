# ==========================================================
# TECHNOBITS - .gitignore
# ==========================================================

# ----------------------------------------------------------
# Dependencies
# ----------------------------------------------------------
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ----------------------------------------------------------
# Next.js
# ----------------------------------------------------------
.next/
out/

# ----------------------------------------------------------
# Build
# ----------------------------------------------------------
build/
dist/

# ----------------------------------------------------------
# Environment Variables (NEVER COMMIT THESE)
# ----------------------------------------------------------
.env
.env.*
!.env.example

# ----------------------------------------------------------
# Vercel
# ----------------------------------------------------------
.vercel/

# ----------------------------------------------------------
# Logs
# ----------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ----------------------------------------------------------
# Coverage
# ----------------------------------------------------------
coverage/

# ----------------------------------------------------------
# TypeScript
# ----------------------------------------------------------
*.tsbuildinfo
next-env.d.ts

# ----------------------------------------------------------
# IDE
# ----------------------------------------------------------
.vscode/
.idea/

# ----------------------------------------------------------
# Operating System Files
# ----------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini

# ----------------------------------------------------------
# Cache
# ----------------------------------------------------------
.cache/
.turbo/

# ----------------------------------------------------------
# Temporary Files
# ----------------------------------------------------------
tmp/
temp/

# ----------------------------------------------------------
# Uploads (if you ever store uploads locally)
# ----------------------------------------------------------
uploads/
public/uploads/

# ----------------------------------------------------------
# Database Files
# ----------------------------------------------------------
*.sqlite
*.sqlite3
*.db

# ----------------------------------------------------------
# Security
# ----------------------------------------------------------
*.pem
*.key
*.crt
*.p12

# ----------------------------------------------------------
# Supabase Local Development
# (Only if you use Supabase CLI later)
# ----------------------------------------------------------
.supabase/

# ----------------------------------------------------------
# Misc
# ----------------------------------------------------------
*.swp
*.swo